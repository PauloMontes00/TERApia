# Example .env (DO NOT commit secrets). Copy to `.env` and fill values.

FRONTEND_URL=http://localhost:5173
PORT=3000

# JWT secret (set in production via secrets manager)
JWT_SECRET=YOUR_JWT_SECRET_HERE

# Master encryption key (min ~32 chars) - store securely in production
ENCRYPTION_KEY=replace_with_secure_key_at_runtime

# Postgres connection (do not include credentials here in public repos)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgis_36_sample
DB_USER=postgres
# DB_PASSWORD should be set in env, secret manager, or CI vault
DB_PASSWORD=*********
