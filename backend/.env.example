# Example backend .env
# Copy to `.env` and fill real values (DO NOT commit secrets)

# Backend port (change to 5173 if you prefer, but frontend defaults to 5173)
PORT=3000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_32_char_encryption_key_here

# Example PostgreSQL connection (replace user/password/host/port as needed)
# The DB_NAME used during development in this workspace: postgis_36_sample
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/postgis_36_sample  # replace with your DB password, or configure trust auth
DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@localhost:5432/postgis_36_sample
